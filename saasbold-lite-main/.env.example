NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Persistence driver: local | supabase
# For Vercel production, set to: supabase
WHATSBOARD_PERSISTENCE_DRIVER=local

# Optional for local fallback and migration scripts
WHATSBOARD_STORE_PATH=/tmp/whatsboard-store.json

# Optional workspace bootstrap defaults
WHATSBOARD_DEFAULT_WORKSPACE_ID=
WHATSBOARD_DEFAULT_WORKSPACE_NAME=WhatsBoard Workspace
